{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "pythonVersion": "3.12"
      }
    }
  ],
  "routes": [
    { "src": "/static/(.*)", "dest": "/frontend/static/$1" },
    { "src": "/manifest.webmanifest", "dest": "/frontend/manifest.webmanifest" },
    { "src": "/service-worker.js", "dest": "/frontend/service-worker.js" },
    { "src": "/api/(.*)", "dest": "api/index.py" },
    { "src": "/(.*)", "dest": "/frontend/index.html" }
  ]
}