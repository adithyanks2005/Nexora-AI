{
  "version": 2,
  "buildCommand": "pip install -r requirements.txt",
  "installCommand": "pip install -r requirements.txt",
  "builds": [
    {
      "src": "backend/main.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "pythonVersion": "3.12"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/backend/main.py"
    }
  ],
  "env": {
    "PYTHON_VERSION": "3.12.10",
    "OPENROUTER_MODEL": "anthropic/claude-sonnet-4.6"
  },
  "functions": {
    "backend/main.py": {
      "maxDuration": 30,
      "memory": 1024
    }
  }
}
