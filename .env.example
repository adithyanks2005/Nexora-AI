# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Google OAuth (required for login)
# Get from: https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# JWT Secret — generate a strong random string for production
# Example: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-this-to-a-strong-random-secret-in-production

# Vercel Environment (set automatically by Vercel)
# VERCEL=1
